<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheet/profile.css">
  </head>
  <body>
    <div class="containerper">
      <div class="cardper">
        <div class="profile-picture">
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?fm=jpg&q=60&w=3000&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8M3x8dXNlcnxlbnwwfHwwfHx8MA%3D%3D" alt="Profile Picture">
        </div>
        <h2 class="fullname"><%= user.fullname %></h2>
        <h3 class="username">@<%= user.username %></h3>
        <p class="tagline">Keep going.</p>
        <p class="description">Some Description</p>
        <a href="/logout" class="button">Log out</a>
        <form action="/upload" method="post" enctype="multipart/form-data">
          <input type="text" name="filecaption" placeholder="Some caption">
          <input type="file" name="file">
          <button type="submit">Upload</button>
        </form>
      </div>

      <div class="cards flex">
        <% if(user.posts.length > 0) { %>
          <% user.posts.forEach(function(post) { %>
            <div class="card" style="width: 18rem;">
              <img src="/images/uploads/<%= post.image %>" class="card-img-top" alt="post image">
              <div class="card-body">
                <h5 class="card-title"><%= post.imageText %></h5>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p>No posts yet.</p>
        <% } %>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>