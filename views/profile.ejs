
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheet/profile.css">

  </head>
  <body>
    <div class="containerper">
    <div class="cardper">
      <div class="profile-picture">
        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?fm=jpg&q=60&w=3000&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8M3x8dXNlcnxlbnwwfHwwfHx8MA%3D%3D" alt="Profile Picture">
      </div>
      <h2 class="fullname"><%= user.username %></h2>
      <h3 class="username">@<%= user.username %></h3>
      <p class="tagline">Keep going.</p>
      <p class="description">Some Description</p>
      <a href="/logout" class="button">Log out</a>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <div class="card" style="width: 18rem;">
  <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQQz5KVqZWJjhpXnCDKhPEmbctV-kV58PJ1vA&s" class="card-img-top" alt="...">
  <div class="card-body">
    <h5 class="card-title">All Design</h5>
  </div>
</div>
</body>
</html>